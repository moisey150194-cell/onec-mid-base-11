	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды	
		
КонецПроцедуры 

&НаКлиенте	
Процедура ПересчитатьТаблицу(Команда) 
	// {{ Моисеев В. П. 29.02.2030
    ПересчитатьТаблицы();
    // }}
КонецПроцедуры 
 
